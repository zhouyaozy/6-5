+package org.apache.commons.cli;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.junit.jupiter.api.Assertions.assertNotNull;
+
+import java.util.Arrays;
+import java.util.Collection;
+
+import org.junit.jupiter.api.Test;
+
+/**
+ * Tests {@link AmbiguousOptionException}.
+ */
+class AmbiguousOptionExceptionTest {
+
+    @Test
+    void testConstructor() {
+        final Collection&lt;String&gt; matchingOptions = Arrays.asList("abc", "abd");
+        final AmbiguousOptionException exception = new AmbiguousOptionException("a", matchingOptions);
+        assertNotNull(exception.getMessage());
+        assertEquals("a", exception.getOption());
+        assertEquals(matchingOptions, exception.getMatchingOptions());
+    }
+}
