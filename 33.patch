+package org.apache.commons.cli;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+
+import java.util.Arrays;
+import java.util.Collection;
+
+import org.junit.jupiter.api.Test;
+
+/**
+ * Tests {@link AmbiguousOptionException}.
+ */
+class AmbiguousOptionExceptionTest {
+
+    @Test
+    void testConstructor() {
+        final Collection<String> matchingOptions = Arrays.asList("a", "b");
+        final AmbiguousOptionException ex = new AmbiguousOptionException("c", matchingOptions);
+        assertEquals("c", ex.getOption());
+        assertEquals(matchingOptions, ex.getMatchingOptions());
+        assertEquals("Ambiguous option: 'c'  (could be: 'a', 'b')", ex.getMessage());
+    }
+}
