+package org.apache.commons.cli;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.junit.jupiter.api.Assertions.assertSame;
+
+import java.util.Arrays;
+import java.util.List;
+
+import org.junit.jupiter.api.Test;
+
+class AmbiguousOptionExceptionTest {
+
+    @Test
+    void testConstructor() {
+        final List<String> matchingOptions = Arrays.asList("version", "verbose");
+        final AmbiguousOptionException exception = new AmbiguousOptionException("--ver", matchingOptions);
+
+        assertEquals("Ambiguous option: '--ver'  (could be: 'version', 'verbose')", exception.getMessage());
+        assertEquals("--ver", exception.getOption());
+        assertSame(matchingOptions, exception.getMatchingOptions());
+    }
+}
